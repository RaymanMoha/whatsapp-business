PORT=8080
BOT_BASE_URL=http://localhost:8080
AUTH_SECRET=replace-with-a-long-random-secret

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# Data storage
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=whatsapp_business

# M-Pesa Daraja STK Push
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
MPESA_BUSINESS_SHORT_CODE=174379
# Sandbox simulator Party A; leave empty in production to use the customer phone.
MPESA_PARTY_A=254708374149
MPESA_PASSKEY=your-daraja-passkey
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_CALLBACK_URL=https://your-public-domain.com/api/commerce/payments/callback

# WAHA
WAHA_BASE_URL=http://localhost:3001
WAHA_API_KEY=change-this-local-api-key
WAHA_SESSION=default
WAHA_REPLY_TO_GROUPS=false

# Bot identity
BOT_NAME=Ask Local
BUSINESS_NAME=Demo Restaurant
HUMAN_HANDOFF_MESSAGE=I do not have confirmed information for that. Please contact a team member for help.
MAX_HISTORY_MESSAGES=8

# Optional Google Sheets and Forms integration
GOOGLE_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/your-sheet-id/edit
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
GOOGLE_INTEGRATION_SECRET=replace-with-another-long-random-secret
